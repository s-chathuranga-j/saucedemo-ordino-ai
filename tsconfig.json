{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],
    "baseUrl": ".",
    "paths": {
      "@pages/*":   ["pages/*"],
      "@panels/*":  ["panels/*"],
      "@config/*":  ["support/config/*"],
      "@data/*":    ["support/data/*"]
    }
  },
  "include": ["tests/**/*", "pages/**/*", "panels/**/*", "support/**/*", "playwright.config.ts"],
  "exclude": ["node_modules"]
}
